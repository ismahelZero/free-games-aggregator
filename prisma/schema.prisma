generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Offer {
  id             String   @id @default(uuid())
  title          String
  thumbnailUrl   String
  platform       String
  originalPrice  Float
  url            String   @unique

  startDate     DateTime @default(now())
  endDate       DateTime?
  
  isActive       Boolean  @default(true) 
  createdAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}